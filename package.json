{
  "name": "abyssal-echo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:client": "npm run dev -w packages/client",
    "dev:server": "npm run dev -w packages/server",
    "clean": "rm -rf packages/shared/dist packages/shared/tsconfig.tsbuildinfo packages/client/dist packages/server/dist",
    "build": "npm run clean && npm run build -w packages/shared && npm run build -w packages/client && npm run build -w packages/server",
    "start": "node packages/server/dist/index.js"
  }
}
